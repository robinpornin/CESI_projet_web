{% extends "base.html.twig" %}

{% block title %}Accueil_invite{% endblock %}

{% block content %}

<div class="bienvenue">
  <span class="tag">Mode Invité</span>
  <h1>Bienvenue sur <span>{{ platform_name }}</span></h1>
  <p>Vous naviguez en tant qu'invité. Vous pouvez rechercher des entreprises et des offres de stage sans vous connecter.</p>
</div>

<div class="separateur"></div>

<div class="section-titre">Que voulez-vous faire ?</div>

<div class="recherche-blocs">

  <div class="recherche-bloc">
    <div class="recherche-bloc-icon">🏢</div>
    <div class="recherche-bloc-info">
      <span class="recherche-bloc-titre">Rechercher une entreprise</span>
      <span class="recherche-bloc-desc">→ Redirection vers la liste des entreprises</span>
      <form method="GET" action="/rechercheEntreprise" class="recherche-input-row">
        <input type="text" name="q" placeholder="Nom, secteur, ville...">
        <button type="submit" class="btn-rechercher">Rechercher</button>
      </form>
    </div>
  </div>

  <div class="recherche-bloc">
    <div class="recherche-bloc-icon">📋</div>
    <div class="recherche-bloc-info">
      <span class="recherche-bloc-titre">Rechercher une offre de stage</span>
      <span class="recherche-bloc-desc">→ Redirection vers la liste des offres</span>
      <form method="GET" action="/rechercheOffre" class="recherche-input-row">
        <input type="text" name="q" placeholder="Poste, compétence, ville...">
        <button type="submit" class="btn-rechercher">Rechercher</button>
      </form>
    </div>
  </div>

</div>

<div class="ou-divider">OU</div>

<div class="connexion-bloc">
  <p>Vous avez un compte ? <span>Connectez-vous</span></p>
  <a href="/connexion" class="btn-connecter">Je veux me connecter</a>
</div>

{% endblock %}