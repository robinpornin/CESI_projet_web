{% extends "base.html.twig" %}

{% block title %}Formulaire{% endblock %}

{% block content %}

<section class="bienvenue">
    <div class="tag">Candidature</div>
    <h1>Postuler à une <span>offre</span></h1>
    <p>Ajoutez votre CV et votre lettre de motivation pour envoyer votre candidature.</p>
</section>

<div class="separateur"></div>
<div class="section-titre">Formulaire de candidature</div>

{% if message %}
    <div class="message-success">{{ message }}</div>
{% endif %}

{% if erreur %}
    <div class="message-erreur">{{ erreur }}</div>
{% endif %}

<form action="" method="post" enctype="multipart/form-data">
    <p>
        <label for="cv">CV (PDF)</label><br>
        <input type="file" id="cv" name="cv" accept=".pdf" required>
    </p>

    <p>
        <label for="lettre_motivation">Lettre de motivation (PDF)</label><br>
        <input type="file" id="lettre_motivation" name="lettre_motivation" accept=".pdf" required>
    </p>

    <button type="submit" class="btn-postuler">Envoyer ma candidature</button>
</form>

{% endblock %}
