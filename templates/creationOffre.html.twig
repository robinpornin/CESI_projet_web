{% extends "base.html.twig" %}

{% block title %}Page de création d'offre{% endblock %}

{% block content %}

<div class="bandeau">
  <div class="bandeau-icon">➕</div>
  <div class="bandeau-info">
    <span class="bandeau-titre">Création d'une offre de stage</span>
    <span class="bandeau-badge">Nouvelle offre</span>
    <span class="bandeau-sous">Remplissez le formulaire pour publier une nouvelle offre.</span>
  </div>
</div>

<main>
  <div class="separateur"></div>

  <div class="form-card">
    <div class="form-card-header">
      <span style="font-size:1rem">📋</span>
      <span class="form-card-header-titre">Formulaire de création</span>
    </div>

    <div class="form-body">

      {% if success %}
        <div style="color: green; margin-bottom: 15px; padding: 10px; border: 1px solid green; border-radius: 6px;">
          L'offre a bien été créée.
        </div>
      {% endif %}

      {% if error %}
        <div style="color: red; margin-bottom: 15px; padding: 10px; border: 1px solid red; border-radius: 6px;">
          {{ error }}
        </div>
      {% endif %}

      {% if entreprises is empty %}
        <div style="color: orange; margin-bottom: 15px; padding: 10px; border: 1px solid orange; border-radius: 6px;">
          Vous devez d'abord créer une entreprise avant de publier une offre.
        </div>
      {% endif %}

      <form method="POST" action="">
        <input type="hidden" name="csrf_token" value="{{ app_csrf_token }}">
        <span class="section-label">Informations générales</span>
        <div class="form-grid">
          <div class="form-group full">
            <label class="form-label" for="titre">Titre de l'offre</label>
            <input
              class="form-input"
              type="text"
              id="titre"
              name="titre"
              placeholder="Ex : Développeur web full-stack"
              maxlength="128"
              required
              value="{{ form.titre|default('') }}"
            >
          </div>

          <div class="form-group">
            <label class="form-label" for="id_entreprise">Entreprise</label>
            <select
              class="form-select"
              id="id_entreprise"
              name="id_entreprise"
              required
              onchange="remplirVilleEntreprise()"
            >
              <option value="">-- Choisir --</option>
              {% for entreprise in entreprises %}
                <option
                  value="{{ entreprise.ID_Entreprise }}"
                  data-ville="{{ entreprise.Secteur }}"
                  {% if form.id_entreprise is defined and form.id_entreprise == entreprise.ID_Entreprise %}selected{% endif %}
                >
                  {{ entreprise.Nom_entreprise }}
                </option>
              {% else %}
                <option value="">Aucune entreprise disponible</option>
              {% endfor %}
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="ville_cp">Localisation (Ville, CP)</label>
            <input
              class="form-input"
              type="text"
              id="ville_cp"
              name="ville_cp"
              placeholder="Ex : Paris 75001"
              maxlength="255"
              required
              readonly
              value="{{ form.ville_cp|default('') }}"
            >
          </div>
        </div>

        <span class="section-label">Durée & Rémunération</span>
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label" for="duree">Durée (semaines)</label>
            <input
              class="form-input"
              type="number"
              id="duree"
              name="duree"
              placeholder="Ex : 6"
              min="1"
              max="24"
              required
              value="{{ form.duree|default('') }}"
            >
          </div>

          <div class="form-group">
            <label class="form-label" for="remuneration">Gratification (€/mois)</label>
            <input
              class="form-input"
              type="number"
              step="0.01"
              id="remuneration"
              name="remuneration"
              placeholder="Ex : 600"
              min="0"
              required
              value="{{ form.remuneration|default('') }}"
            >
          </div>

          <div class="form-group">
            <label class="form-label" for="date_debut">Date de début</label>
            <input
              class="form-input"
              type="date"
              id="date_debut"
              name="date_debut"
              required
              value="{{ form.date_debut|default('') }}"
            >
          </div>
        </div>

        <span class="section-label">Description</span>
        <div class="form-group">
          <label class="form-label" for="description">Description du poste</label>
          <textarea
            class="form-textarea"
            id="description"
            name="description"
            placeholder="Décrivez les missions, le contexte, les objectifs…"
            maxlength="512"
            required
          >{{ form.description|default('') }}</textarea>
        </div>

        <span class="section-label">Compétences requises</span>
        <div class="form-group">
          <label class="form-label">Sélectionnez les compétences</label>
          <div class="tags-container" style="display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 0.75rem;">
            {% for competence in competences %}
              <label class="tag-checkbox">
                <input
                  type="checkbox"
                  name="competences[]"
                  value="{{ competence.ID_Competence }}"
                  {% if competence.ID_Competence in form.competences|default([]) %}checked{% endif %}
                >
                <span>{{ competence.Nom_competence }}</span>
              </label>
            {% else %}
              <p style="color: var(--text-muted)">Aucune compétence disponible.</p>
            {% endfor %}
          </div>
          <span class="tags-hint">Cochez une ou plusieurs compétences.</span>
        </div>

        <div class="form-actions">
          <button class="btn-submit" type="submit" {% if entreprises is empty %}disabled{% endif %}>
            Publier l'offre
          </button>
          <button class="btn-reset" type="reset">
            Réinitialiser
          </button>
        </div>
      </form>

    </div>
  </div>
</main>

<script>
function remplirVilleEntreprise() {
  const select = document.getElementById('id_entreprise');
  const inputVille = document.getElementById('ville_cp');

  if (!select || !inputVille) {
    return;
  }

  const optionSelectionnee = select.options[select.selectedIndex];

  if (optionSelectionnee && optionSelectionnee.dataset.ville) {
    inputVille.value = optionSelectionnee.dataset.ville;
  } else {
    inputVille.value = '';
  }
}

document.addEventListener('DOMContentLoaded', function () {
  remplirVilleEntreprise();
});
</script>

{% endblock %}
