{% extends "base.html.twig" %}

{% block title %}Page élève{% endblock %}

{% block content %}

<!-- bandeau bienvenue -->
  <div class="bandeau">
    <div class="bandeau-avatar">🎓</div>
    <div class="bandeau-info">
      <span class="bandeau-titre">Bienvenue, {{prenom}} !</span>
      <span class="bandeau-badge">Espace Étudiant</span>
      <span class="bandeau-sous">Recherchez des entreprises, des offres et gérez votre compte.</span>
    </div>
  </div>

    <div class="separateur"></div>
    <div class="section-titre">Que voulez-vous faire ?</div>

    <!-- GROUPE 1 : Recherches -->
    <div class="groupe">
      <div class="groupe-label">Recherches</div>

      <!-- recherche entreprise -->
      <a class="action-bloc" href="/rechercheEntreprise">
        <div class="action-icon">🏢</div>
        <div class="action-info">
          <span class="action-titre">Rechercher une entreprise</span>
          <span class="action-desc">→ Redirection vers la liste des entreprises</span>
        </div>
        <span style="font-size:1.2rem; color:#FFD700; font-weight:900;">›</span>
      </a>

      <!-- recherche offre -->
      <a class="action-bloc" href="/rechercheOffre">
        <div class="action-icon">📋</div>
        <div class="action-info">
          <span class="action-titre">Rechercher une offre de stage</span>
          <span class="action-desc">→ Redirection vers la liste des offres</span>
        </div>
        <span style="font-size:1.2rem; color:#FFD700; font-weight:900;">›</span>
      </a>
    </div>

    <div class="divider"></div>

    <!-- GROUPE 2 : Mon compte -->
    <div class="groupe">
      <div class="groupe-label">Mon compte</div>

      <!-- accès compte étudiant -->
      <a class="action-bloc" href="/gestionCompte">
        <div class="action-icon">🪪</div>
        <div class="action-info">
          <span class="action-titre">Accéder à mon compte étudiant</span>
          <span class="action-desc">→ Redirection vers la page du compte étudiant</span>
        </div>
        <span style="font-size:1.2rem; color:#FFD700; font-weight:900;">›</span>
      </a>
    </div>

{% endblock %}
