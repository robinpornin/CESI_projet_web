{% extends "base.html.twig" %}

{% block title %}Page élève{% endblock %}

{% block content %}

<!-- bandeau bienvenue -->
  <div class="bandeau">
    <div class="bandeau-avatar">🎓</div>
    <div class="bandeau-info">
      <span class="bandeau-titre">Bienvenue, Étudiant 👋</span>
      <span class="bandeau-badge">Espace Étudiant</span>
      <span class="bandeau-sous">Recherchez des entreprises, des offres et gérez votre compte.</span>
    </div>
  </div>

  <!-- main -->

    <div class="separateur"></div>
    <div class="section-titre">Que voulez-vous faire ?</div>

    <!-- GROUPE 1 : Recherches -->
    <div class="groupe">
      <div class="groupe-label">Recherches</div>

      <!-- recherche entreprise -->
      <div class="action-bloc">
        <div class="action-icon">🏢</div>
        <div class="action-info">
          <span class="action-titre">Rechercher une entreprise</span>
          <span class="action-desc">→ Redirection vers la liste des entreprises</span>
          <div class="action-input-row">
            <input type="text" id="inputEntreprise" placeholder="Nom, secteur, ville...">
            <button class="btn-action" onclick="go('/rechercheEntreprise', 'inputEntreprise')">Rechercher</button>
          </div>
        </div>
      </div>

      <!-- recherche offre -->
      <div class="action-bloc">
        <div class="action-icon">📋</div>
        <div class="action-info">
          <span class="action-titre">Rechercher une offre de stage</span>
          <span class="action-desc">→ Redirection vers la liste des offres</span>
          <div class="action-input-row">
            <input type="text" id="inputOffre" placeholder="Poste, compétence, ville...">
            <button class="btn-action" onclick="go('recherche-offre.html', 'inputOffre')">Rechercher</button>
          </div>
        </div>
      </div>

      <!-- recherche offre statistiques -->
      <div class="action-bloc stat-bloc">
        <div class="action-icon">📊</div>
        <div class="action-info">
          <span class="action-titre">Rechercher une offre <em>(avec statistiques)</em></span>
          <span class="action-desc">→ Redirection vers la liste des offres avec statistiques</span>
          <span class="action-tag">Stats incluses</span>
          <div class="action-input-row">
            <input type="text" id="inputOffreStat" placeholder="Poste, compétence, ville...">
            <button class="btn-action" onclick="go('recherche-offre-stats.html', 'inputOffreStat')">Rechercher</button>
          </div>
        </div>
      </div>
    </div>

    <div class="divider"></div>

    <!-- GROUPE 2 : Mon compte -->
    <div class="groupe">
      <div class="groupe-label">Mon compte</div>

      <!-- recherche compte étudiant -->
      <div class="action-bloc">
        <div class="action-icon">🪪</div>
        <div class="action-info">
          <span class="action-titre">Accéder à un compte étudiant</span>
          <span class="action-desc">→ Redirection vers la page du compte étudiant recherché</span>
          <div class="action-input-row">
            <input type="text" id="inputCompte" placeholder="Nom, prénom, email...">
            <button class="btn-action" onclick="go('compte-etudiant.html', 'inputCompte')">Rechercher</button>
          </div>
        </div>
      </div>
    </div>

{% endblock %}