{% extends 'base.html.twig' %}

{% block title %}Mes Candidatures{% endblock %}

{% block content %}

<div class="bandeau">
  <div class="bandeau-icon">📋</div>
  <div class="bandeau-info">
    <span class="bandeau-titre">Mes Candidatures</span>
    <span class="bandeau-badge">Élève</span>
  </div>
</div>

{% if candidatures is empty %}

  <div class="demo-hint">
    <div class="big">📭</div>
    <strong>Aucune candidature pour le moment</strong>
  </div>

{% else %}

  <div class="liste-offres">
    {% for c in candidatures %}
    <div class="offre-card">

      <div class="offre-top">
        <span class="offre-titre">{{ c.Titre }}</span>
        <span class="offre-badge">{{ c.Nom_entreprise }}</span>
      </div>

      <div class="offre-meta">
        <span>📅 {{ c.Date_ }}</span>
        <span>📍 {{ c.Ville_CP }}</span>
      </div>

      <div class="fiche-actions">
        {% if c.CV %}
          <iframe src="/file?path=cv/{{ c.CV }}"
                  width="100%"
                  height="500px"
                  type="application/pdf">
            <a href="/file?path=cv/{{ c.CV }}" target="_blank">📄 Voir le CV</a>
          </iframe>
        {% endif %}

        {% if c.Lettre_de_motivation %}
          <iframe src="/file?path=lettres/{{ c.Lettre_de_motivation }}"
                  width="100%"
                  height="500px"
                  type="application/pdf">
            <a href="/file?path=lettres/{{ c.Lettre_de_motivation }}" target="_blank">✉️ Voir la lettre</a>
          </iframe>
        {% endif %}
      </div>

    </div>
    {% endfor %}
  </div>

{% endif %}

{% endblock %}