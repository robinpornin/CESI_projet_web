{% extends "base.html.twig" %}

{% block title %}Page de l'offre{% endblock %}

{% block content %}

    <!-- intitulé -->
    <div class="intitule-card">
      <div class="intitule-top">
        <span class="intitule-titre">{{ offre.Titre }}</span>
      </div>
      <div class="intitule-meta">
        <div class="meta-item"><span>🏢</span> {{ offre.Nom_entreprise }}</div>
        <div class="meta-item"><span>📍</span> {{ offre.Ville_CP }}</div>
        <div class="meta-item"><span>💶</span> {{ offre.Remuneration }} €/mois</div>
      </div>
    </div>

    <!-- description -->
    <div class="desc-card">
      <div class="desc-card-header">
        <span style="font-size:1rem">📄</span>
        <span class="desc-card-header-titre">Description du stage</span>
      </div>
      <div class="desc-body">

        <span class="desc-section-titre">Missions</span>
        <p class="desc-texte">{{ offre.Description }}</p>

        <span class="desc-section-titre">Compétences requises</span>
        <div class="tags-list">
          {% for competence in competences %}
            <span class="tag">{{ competence.Nom_competence }}</span>
          {% else %}
            <span>Aucune compétence renseignée.</span>
          {% endfor %}
        </div>

        <span class="desc-section-titre">Informations pratiques</span>
        <div class="infos-grid">
          <div class="info-item">
            <span class="info-label">Durée</span>
            <span class="info-value">{{ offre.Duree }} mois</span>
          </div>
          <div class="info-item">
            <span class="info-label">Date de début</span>
            <span class="info-value">{{ offre.Date_ }}</span>
          </div>
        </div>

      </div>
    </div>

    <!-- actions -->
    <div class="actions-row">
      <button class="btn-postuler" onclick="window.location.href='/formulaire'">Postuler</button>
      <button class="btn-wishlist {% if inWishlist %}active{% endif %}" 
              id="btnWishlist" onclick="toggleWishlist()">
          {{ inWishlist ? 'Retirer de la wishlist' : 'Ajouter à la wishlist' }}
      </button>
    </div>

<!-- statistiques -->
<div class="stats-card">

  <div class="stats-body" style="display: block;">

    <div class="stats-grid">

  <div class="stat-item">
    <span class="stat-icon">📩</span>
    <span class="stat-value">{{ stats.nb_postulations }}</span>
    <span class="stat-label">Postulations</span>
  </div>

  <div class="stat-item">
    <span class="stat-icon">❤️</span>
    <span class="stat-value">{{ stats.nb_wishlist }}</span>
    <span class="stat-label">Wishlist</span>
  </div>

  <div class="stat-item">
    <span class="stat-icon">⭐</span>
    <span class="stat-value">{{ stats.note_entreprise|default('—') }}</span>
    <span class="stat-label">Note entreprise</span>
  </div>

</div>

  </div>

</div>



<script>
let dansMaWishlist = {{ inWishlist ? 'true' : 'false' }};

async function toggleWishlist() {
    const btn = document.getElementById('btnWishlist');
    const idOffre = {{ offre.ID_Offre }};

    const url = dansMaWishlist ? '/supprimerWishlist.php' : '/ajouterWishlist.php';
    const res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id_offre: idOffre })
    });
    const data = await res.json();
    if (data.success) {
        dansMaWishlist = !dansMaWishlist;
        btn.textContent = dansMaWishlist ? 'Retirer de la wishlist' : 'Ajouter à la wishlist';
        btn.classList.toggle('active');
    } else {
        alert(data.message || 'Erreur');
    }
}
</script>


{% endblock %}