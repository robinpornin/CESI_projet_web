{% extends "base.html.twig" %}

{% block title %}Page de l'offre{% endblock %}

{% block content %}

    <!-- intitulé -->
    <div class="intitule-card">
      <div class="intitule-top">
        <span class="intitule-titre">{{ offre.Titre }}</span>
      </div>
      <div class="intitule-meta">
        <div class="meta-item"><span>🏢</span> {{ offre.Nom_entreprise }}</div>
        <div class="meta-item"><span>📍</span> {{ offre.Ville_CP }}</div>
        <div class="meta-item"><span>💶</span> {{ offre.Remuneration }} €/mois</div>
      </div>
    </div>

    <!-- description -->
    <div class="desc-card">
      <div class="desc-card-header">
        <span style="font-size:1rem">📄</span>
        <span class="desc-card-header-titre">Description du stage</span>
      </div>
      <div class="desc-body">

        <span class="desc-section-titre">Missions</span>
        <p class="desc-texte">{{ offre.Description }}</p>

        <span class="desc-section-titre">Compétences requises</span>
        <div class="tags-list">
          {% for competence in competences %}
            <span class="tag">{{ competence.Nom_competence }}</span>
          {% else %}
            <span>Aucune compétence renseignée.</span>
          {% endfor %}
        </div>

        <span class="desc-section-titre">Informations pratiques</span>
        <div class="infos-grid">
          <div class="info-item">
            <span class="info-label">Durée</span>
            <span class="info-value">{{ offre.Duree }} mois</span>
          </div>
          <div class="info-item">
            <span class="info-label">Date de début</span>
            <span class="info-value">{{ offre.Date_ }}</span>
          </div>
        </div>

      </div>
    </div>

    <!-- actions -->
    <div class="actions-row">
      <button class="btn-postuler" onclick="postuler()">Postuler</button>
      <button class="btn-wishlist" id="btnWishlist" onclick="toggleWishlist()">Ajouter à la wishlist</button>
    </div>

    <!-- statistiques -->
    <div class="stats-card">
      <button class="stats-toggle" onclick="toggleStats()">
        <span>Afficher les statistiques de l'offre</span>
        <span class="stats-arrow" id="statsArrow">▼</span>
      </button>
      <div class="stats-body" id="statsBody">

        <div class="stats-grid">
          <div class="stat-item highlight">
            <span class="stat-icon">👁️</span>
            <span class="stat-value">{{ stats.nb_vues }}</span>
            <span class="stat-label">Vues</span>
          </div>
          <div class="stat-item">
            <span class="stat-icon">📩</span>
            <span class="stat-value">{{ stats.nb_candidatures }}</span>
            <span class="stat-label">Candidatures</span>
          </div>
        </div>

        <div class="progress-bar-bg">
          <div class="progress-bar-fill" style="width: {{ stats.taux_wishlist }}%"></div>
        </div>

        <div class="progress-row">
          <div class="progress-label-row">
            <span>Taux d'ajout wishlist : </span>
            <span>{{ stats.taux_wishlist }} %</span>
          </div>
        </div>

      </div>
    </div>

{% endblock %}