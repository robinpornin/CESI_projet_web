{% extends "base.html.twig" %}

{% block title %}Accueil{% endblock %}

{% block content %}

<!-- bandeau -->
  <div class="bandeau">
    <div class="bandeau-icon">🎓</div>
    <div class="bandeau-info">
      <span class="bandeau-titre">Création d'un compte Élève</span>
      <span class="bandeau-badge">Nouveau profil</span>
      <span class="bandeau-sous">Remplissez le formulaire pour créer un nouveau compte élève.</span>
    </div>
  </div>

    <div class="separateur"></div>

    <div class="form-card">
      <div class="form-card-header">
        <span class="form-card-header-icon">📋</span>
        <span class="form-card-header-titre">Formulaire de création</span>
      </div>

      <div class="form-body">

        <!-- identité -->
        <span class="section-label">Identité</span>
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Prénom</label>
            <input class="form-input" type="text" placeholder="Alice">
          </div>
          <div class="form-group">
            <label class="form-label">Nom</label>
            <input class="form-input" type="text" placeholder="Martin">
          </div>
          <div class="form-group full">
            <label class="form-label">Email</label>
            <input class="form-input" type="email" placeholder="alice.martin@viacesi.fr">
          </div>
        </div>

        <!-- scolarité -->
        <span class="section-label">Scolarité</span>
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Centre CESI</label>
            <input class="form-input" type="text" placeholder="Paris, Lyon…">
          </div>
          <div class="form-group">
            <label class="form-label">Promotion</label>
            <input class="form-input" type="text" placeholder="2024-2026">
          </div>
          <div class="form-group">
            <label class="form-label">Spécialité</label>
            <select class="form-select">
              <option value="">-- Choisir --</option>
              <option>Informatique</option>
              <option>Génie Civil</option>
              <option>Électronique</option>
              <option>Management</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Statut</label>
            <select class="form-select">
              <option value="">-- Choisir --</option>
              <option>Actif</option>
              <option>En stage</option>
              <option>Inactif</option>
            </select>
          </div>
        </div>

        <!-- mot de passe -->
        <span class="section-label">Sécurité</span>
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Mot de passe</label>
            <input class="form-input" type="password" id="mdp" placeholder="••••••••" oninput="checkStrength(this.value)">
            <div class="mdp-strength">
              <div class="mdp-bar" id="bar1"></div>
              <div class="mdp-bar" id="bar2"></div>
              <div class="mdp-bar" id="bar3"></div>
            </div>
            <span class="mdp-hint" id="mdpHint">Minimum 8 caractères</span>
          </div>
          <div class="form-group">
            <label class="form-label">Confirmer le mot de passe</label>
            <input class="form-input" type="password" id="mdpConfirm" placeholder="••••••••" oninput="checkMatch()">
            <span class="mdp-hint" id="matchHint"></span>
          </div>
        </div>

        <!-- actions -->
        <div class="form-actions">
          <button class="btn-submit" onclick="soumettre()">Créer le compte</button>
          <button class="btn-reset" onclick="document.querySelector('form') && document.querySelector('form').reset()">Réinitialiser</button>
        </div>

      </div>
    </div>

{% endblock %}