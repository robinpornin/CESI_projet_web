{% extends "base.html.twig" %}

{% block title %}page de la recherche d'offre{% endblock %}

{% block content %}

<style>
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 18px;
    padding-top: 8px;
  }

  .pagination .page-btn {
    display: inline-block;
    padding: 8px 14px;
    border: 1px solid #111;
    border-radius: 8px;
    background-color: #fff;
    color: #111;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .pagination .page-btn:hover {
    background-color: #f7c600;
    border-color: #f7c600;
    color: #111;
  }

  .pagination .page-btn.active {
    background-color: #111;
    color: #f7c600;
    border-color: #111;
  }

  .liste-offres .pagination {
    width: 100%;
  }
   .top-section {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .bienvenue {
    text-align: center;
  }
</style>

<div class="top-section">
  <div class="bienvenue">
    <h1>Recherche d'<span>Offres de Stage</span></h1>
    <p>Parcourez les offres disponibles et postulez en un clic.</p>
  </div>
  <div class="search-bar">
    <form method="get" action="" style="display:flex; align-items:center; width:100%; gap:0;">
      <input type="text" id="searchInput" name="search" placeholder="Titre, entreprise, secteur..." value="{{ search|default('') }}">
      <div class="divider-v"></div>
      <select id="filterVille" name="ville">
        <option value="">Toutes les villes</option>
        {% for ville in villes %}
          <option value="{{ ville }}" {% if selectedVille is defined and selectedVille == ville %}selected{% endif %}>{{ ville }}</option>
        {% endfor %}
      </select>
      <div class="divider-v"></div>
      <select id="filterDuree" name="duree">
        <option value="">⏱ Toutes durées</option>
        <option value="8" {% if selectedDuree is defined and selectedDuree == '8' %}selected{% endif %}>8 semaines</option>
        <option value="10" {% if selectedDuree is defined and selectedDuree == '10' %}selected{% endif %}>10 semaines</option>
        <option value="12" {% if selectedDuree is defined and selectedDuree == '12' %}selected{% endif %}>12 semaines</option>
        <option value="14" {% if selectedDuree is defined and selectedDuree == '14' %}selected{% endif %}>14 semaines</option>
        <option value="16" {% if selectedDuree is defined and selectedDuree == '16' %}selected{% endif %}>16 semaines</option>
        <option value="18" {% if selectedDuree is defined and selectedDuree == '18' %}selected{% endif %}>18 semaines</option>
        <option value="20" {% if selectedDuree is defined and selectedDuree == '20' %}selected{% endif %}>20 semaines</option>
      </select>
      <button class="btn-search" type="submit">Rechercher</button>
    </form>
  </div>
</div>

<div class="separateur"></div>

<div class="content-layout">

  <div class="liste-offres">
    <div style="display:flex;justify-content:space-between;align-items:center;">
      <div class="liste-title">Liste des offres</div>
      <span class="results-count" id="resultsCount"></span>
    </div>

    <div id="listeContainer"></div>

    {% if totalPages > 1 %}
      <div class="pagination">
        {% if currentPage > 1 %}
          <a href="?page={{ currentPage - 1 }}&search={{ search|url_encode }}&ville={{ selectedVille|url_encode }}&duree={{ selectedDuree|url_encode }}" class="page-btn">Précédent</a>
        {% endif %}

        {% for i in 1..totalPages %}
          {% if i == currentPage %}
            <span class="page-btn active">{{ i }}</span>
          {% else %}
            <a href="?page={{ i }}&search={{ search|url_encode }}&ville={{ selectedVille|url_encode }}&duree={{ selectedDuree|url_encode }}" class="page-btn">{{ i }}</a>
          {% endif %}
        {% endfor %}

        {% if currentPage < totalPages %}
          <a href="?page={{ currentPage + 1 }}&search={{ search|url_encode }}&ville={{ selectedVille|url_encode }}&duree={{ selectedDuree|url_encode }}" class="page-btn">Suivant</a>
        {% endif %}
      </div>
    {% endif %}
  </div>

  <div class="fiche-offre">
    <h3>Postuler</h3>

    <div class="fiche-placeholder" id="fichePlaceholder">
      <span class="icon">📄</span>
      <span>Sélectionnez une offre pour voir les détails</span>
    </div>

    <div class="fiche-content" id="ficheContent">
      <div class="fiche-row">
        <span class="fiche-label">Poste</span>
        <span class="fiche-value" id="fichePoste">—</span>
      </div>
      <div class="fiche-row">
        <span class="fiche-label">Entreprise</span>
        <span class="fiche-value" id="ficheEntreprise">—</span>
      </div>
      <div class="fiche-row">
        <span class="fiche-label">Secteur</span>
        <span class="fiche-value" id="ficheSecteur">—</span>
      </div>
      <div class="fiche-row">
        <span class="fiche-label">Ville</span>
        <span class="fiche-value" id="ficheVille">—</span>
      </div>
      <div class="fiche-row">
        <span class="fiche-label">Durée</span>
        <span class="fiche-value" id="ficheDuree">—</span>
      </div>
      <div class="fiche-row">
        <span class="fiche-label">Gratification</span>
        <span class="fiche-value" id="ficheGrat">—</span>
      </div>
      <div class="fiche-row">
        <span class="fiche-label">Date de début</span>
        <span class="fiche-value" id="ficheDate">—</span>
      </div>

      <button class="btn-postuler" id="btnPostuler">✉️ Postuler</button>
      <button class="btn-fiche-detail" id="btnDetail">Voir la fiche complète →</button>
    </div>
  </div>

</div>

<script>
  const offres = {{ offres | json_encode | raw }};

  let activeIndex = null;

  function renderOffres(list) {
    const container = document.getElementById('listeContainer');
    const count = document.getElementById('resultsCount');

    count.textContent = list.length + ' offre(s) trouvée(s)';
    container.innerHTML = '';

    if (list.length === 0) {
      container.innerHTML = '<p style="color:#aaa;font-style:italic;font-size:0.85rem;padding:10px 0;">Aucune offre trouvée.</p>';
      return;
    }

    list.forEach((o, i) => {
      const card = document.createElement('div');
      card.className = 'offre-card' + (activeIndex === i ? ' active' : '');
      card.innerHTML = `
        <div class="offre-top">
          <span class="offre-titre">${o.Titre}</span>
          <span class="offre-badge">${o.Duree} semaines</span>
        </div>
        <div class="offre-meta">
          <span>🏢 ${o.Nom_entreprise}</span>
          <span>📍 ${o.Ville_CP}</span>
          <span>💰 ${o.Remuneration} €/mois</span>
        </div>
      `;
      card.onclick = () => selectOffre(i, list);
      container.appendChild(card);
    });
  }

  function selectOffre(index, list) {
    activeIndex = index;
    const o = list[index];

    document.getElementById('fichePoste').textContent = o.Titre;
    document.getElementById('ficheEntreprise').textContent = o.Nom_entreprise;
    document.getElementById('ficheSecteur').textContent = o.Secteur;
    document.getElementById('ficheVille').textContent = o.Ville_CP;
    document.getElementById('ficheDuree').textContent = o.Duree + ' semaines';
    document.getElementById('ficheGrat').textContent = o.Remuneration + ' €/mois';
    document.getElementById('ficheDate').textContent = o.Date_;

    document.getElementById('btnPostuler').onclick = () => {
      window.location.href = `postuler.php?id=${o.ID_Offre}`;
    };

    document.getElementById('btnDetail').onclick = () => {
      window.location.href = `ficheOffre.php?id=${o.ID_Offre}`;
    };

    document.getElementById('fichePlaceholder').style.display = 'none';
    document.getElementById('ficheContent').classList.add('visible');

    renderOffres(list);
  }

  renderOffres(offres);
</script>

{% endblock %}
