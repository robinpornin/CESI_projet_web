{% extends "base.html.twig" %}

{% block title %}Page de la geestion des comptes pilotes par l'administrateur{% endblock %}

{% block content %}

<!-- bandeau -->
  <div class="bandeau">
    <div class="bandeau-icon">🧑‍✈️</div>
    <div class="bandeau-info">
      <span class="bandeau-titre">Gestion des comptes Pilotes</span>
      <span class="bandeau-badge">Espace Admin</span>
      <span class="bandeau-sous">Créez, modifiez ou supprimez des comptes pilotes.</span>
    </div>
  </div>

  <!-- main -->
    <div class="separateur"></div>

    <!-- créer compte pilote -->
    <div class="creer-bloc">
      <button class="creer-toggle-btn" onclick="toggleCreer()">
        <span>Créer un compte Pilote</span>
        <span class="creer-arrow" id="creerArrow">▼</span>
      </button>
      <div class="creer-form" id="creerForm">
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Prénom</label>
            <input class="form-input" type="text" placeholder="Jean">
          </div>
          <div class="form-group">
            <label class="form-label">Nom</label>
            <input class="form-input" type="text" placeholder="Dupont">
          </div>
          <div class="form-group full">
            <label class="form-label">Email</label>
            <input class="form-input" type="email" placeholder="jean.dupont@cesi.fr">
          </div>
          <div class="form-group">
            <label class="form-label">Mot de passe</label>
            <input class="form-input" type="password" placeholder="••••••••">
          </div>
          <div class="form-group">
            <label class="form-label">Centre CESI</label>
            <input class="form-input" type="text" placeholder="Paris, Lyon...">
          </div>
        </div>
        <button class="btn-creer">Créer le compte</button>
      </div>
    </div>

    <!-- recherche pilote -->
    <div class="recherche-bloc">
      <div class="bloc-header">Rechercher un pilote</div>
      <div class="bloc-body">
        <div class="search-row">
          <input type="text" id="searchPilote" placeholder="Nom, prénom, email...">
          <button class="btn-search" onclick="rechercherPilote()">Rechercher</button>
        </div>
      </div>
    </div>

    <!-- fiche pilote -->
    <div class="fiche-pilote" id="fichePilote">
      <div class="bloc-header">Informations du pilote</div>

      <div class="fiche-placeholder" id="fichePlaceholder">
        <span class="big-icon">🧑‍✈️</span>
        <span>Effectuez une recherche pour afficher et modifier les informations d'un pilote.</span>
      </div>

      <div class="fiche-content" id="ficheContent">
        <div class="fiche-top">
          <div class="pilote-avatar">🧑‍✈️</div>
          <div>
            <div class="pilote-nom" id="ficheNomAffiche">Jean Dupont</div>
            <div class="pilote-email" id="ficheEmailAffiche">jean.dupont@cesi.fr</div>
          </div>
        </div>
        <div class="fiche-fields">
          <div class="field-group">
            <label class="field-label">Prénom</label>
            <input class="field-input" id="fichePrenom" type="text" value="Jean">
          </div>
          <div class="field-group">
            <label class="field-label">Nom</label>
            <input class="field-input" id="ficheNom" type="text" value="Dupont">
          </div>
          <div class="field-group full">
            <label class="field-label">Email</label>
            <input class="field-input" id="ficheEmail" type="email" value="jean.dupont@cesi.fr">
          </div>
          <div class="field-group">
            <label class="field-label">Centre CESI</label>
            <input class="field-input" id="ficheCentre" type="text" value="Paris">
          </div>
          <div class="field-group">
            <label class="field-label">Statut</label>
            <input class="field-input" id="ficheStatut" type="text" value="Actif">
          </div>
        </div>
        <div class="fiche-actions">
          <button class="btn-enregistrer" onclick="enregistrer()">Enregistrer</button>
          <button class="btn-supprimer" onclick="supprimerCompte()">Supprimer le compte</button>
        </div>
      </div>
    </div>

{% endblock %}