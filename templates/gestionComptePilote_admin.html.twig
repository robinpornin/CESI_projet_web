{% extends "base.html.twig" %}

{% block title %}Page de la gestion des comptes pilotes par l'administrateur{% endblock %}

{% block content %}

  <div class="bandeau">
    <div class="bandeau-icon">🧑‍✈️</div>
    <div class="bandeau-info">
      <span class="bandeau-titre">Gestion des comptes Pilotes</span>
      <span class="bandeau-badge">Espace Admin</span>
      <span class="bandeau-sous">Créez, modifiez ou supprimez des comptes pilotes.</span>
    </div>
  </div>

  <div class="separateur"></div>

  <div class="creer-bloc">
    <button type="button" class="creer-toggle-btn" onclick="toggleCreer()">
      <span>Créer un compte Pilote</span>
      <span class="creer-arrow" id="creerArrow">▼</span>
    </button>

    <div class="creer-form" id="creerForm">
      <div class="form-grid">
        <div class="form-group">
          <label class="form-label" for="createPrenom">Prénom</label>
          <input class="form-input" id="createPrenom" type="text" placeholder="Jean">
        </div>
        <div class="form-group">
          <label class="form-label" for="createNom">Nom</label>
          <input class="form-input" id="createNom" type="text" placeholder="Dupont">
        </div>
        <div class="form-group full">
          <label class="form-label" for="createEmail">Email</label>
          <input class="form-input" id="createEmail" type="email" placeholder="jean.dupont@cesi.fr">
        </div>
        <div class="form-group full">
          <label class="form-label" for="createPassword">Mot de passe</label>
          <input class="form-input" id="createPassword" type="password" placeholder="••••••••">
        </div>
      </div>
      <button type="button" class="btn-creer" onclick="creerCompte()">Créer le compte</button>
    </div>
  </div>

  <div class="recherche-bloc">
    <div class="bloc-header">Rechercher un pilote</div>
    <div class="bloc-body">
      <div class="search-row">
        <input type="text" id="searchPilote" placeholder="Nom, prénom, email...">
        <button type="button" class="btn-search" onclick="rechercherPilote()">Rechercher</button>
      </div>
    </div>
  </div>

  <div class="fiche-pilote" id="fichePilote">
    <div class="bloc-header">Informations du pilote</div>

    <div class="fiche-placeholder" id="fichePlaceholder">
      <span class="big-icon">🧑‍✈️</span>
      <span>Effectuez une recherche pour afficher et modifier les informations d'un pilote.</span>
    </div>

    <div class="fiche-content" id="ficheContent" data-id="">
      <div class="fiche-top">
        <div class="pilote-avatar">🧑‍✈️</div>
        <div>
          <div class="pilote-nom" id="ficheNomAffiche"></div>
          <div class="pilote-email" id="ficheEmailAffiche"></div>
        </div>
      </div>

      <div class="fiche-fields">
        <div class="field-group">
          <label class="field-label" for="fichePrenom">Prénom</label>
          <input class="field-input" id="fichePrenom" type="text" value="">
        </div>
        <div class="field-group">
          <label class="field-label" for="ficheNom">Nom</label>
          <input class="field-input" id="ficheNom" type="text" value="">
        </div>
        <div class="field-group full">
          <label class="field-label" for="ficheEmail">Email</label>
          <input class="field-input" id="ficheEmail" type="email" value="">
        </div>
      </div>

      <div class="fiche-actions">
        <button type="button" class="btn-enregistrer" onclick="enregistrer()">Enregistrer</button>
        <button type="button" class="btn-supprimer" onclick="supprimerCompte()">Supprimer le compte</button>
      </div>
    </div>
  </div>

  <script>
    let pilotes = {{ pilotes|json_encode|raw }};
    pilotes = Array.isArray(pilotes) ? pilotes.filter(p => p && p.ID_Utilisateur) : [];

    function toggleCreer() {
      const form = document.getElementById('creerForm');
      const arrow = document.getElementById('creerArrow');

      if (form.style.display === 'block') {
        form.style.display = 'none';
        arrow.textContent = '▼';
      } else {
        form.style.display = 'block';
        arrow.textContent = '▲';
      }
    }

     function rechercherPilote() {
    const valeur = document.getElementById('searchPilote').value
      .toLowerCase()
      .trim()
      .replace(/\s+/g, ' ');

    if (!valeur) {
      alert('Veuillez saisir un nom, prénom ou email.');
      return;
    }

    const pilote = pilotes.find(function(p) {
      if (!p) return false;

      const nom = (p.Nom || '').toLowerCase().trim();
      const prenom = (p.Prenom || '').toLowerCase().trim();
      const email = (p.Email || '').toLowerCase().trim();

      const nomPrenom = (nom + ' ' + prenom).replace(/\s+/g, ' ').trim();
      const prenomNom = (prenom + ' ' + nom).replace(/\s+/g, ' ').trim();

      return (
        nom.includes(valeur) ||
        prenom.includes(valeur) ||
        email.includes(valeur) ||
        nomPrenom.includes(valeur) ||
        prenomNom.includes(valeur)
      );
    });

    if (!pilote) {
      document.getElementById('fichePlaceholder').style.display = 'flex';
      document.getElementById('ficheContent').style.display = 'none';
      alert('Aucun pilote trouvé.');
      return;
    }

    afficherPilote(pilote);
  }

    function afficherPilote(pilote) {
      if (!pilote) {
        console.error('Pilote invalide reçu dans afficherPilote :', pilote);
        return;
      }

      document.getElementById('fichePlaceholder').style.display = 'none';
      document.getElementById('ficheContent').style.display = 'block';

      document.getElementById('ficheContent').dataset.id = pilote.ID_Utilisateur || '';
      document.getElementById('ficheNomAffiche').textContent = ((pilote.Prenom || '') + ' ' + (pilote.Nom || '')).trim();
      document.getElementById('ficheEmailAffiche').textContent = pilote.Email || '';

      document.getElementById('fichePrenom').value = pilote.Prenom || '';
      document.getElementById('ficheNom').value = pilote.Nom || '';
      document.getElementById('ficheEmail').value = pilote.Email || '';
    }

    async function creerCompte() {
      const prenom = document.getElementById('createPrenom').value.trim();
      const nom = document.getElementById('createNom').value.trim();
      const email = document.getElementById('createEmail').value.trim();
      const mdp = document.getElementById('createPassword').value.trim();

      if (!prenom || !nom || !email || !mdp) {
        alert('Merci de remplir tous les champs.');
        return;
      }

      try {
        const response = await fetch('/gestionComptePiloteAdmin', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            action: 'create',
            prenom: prenom,
            nom: nom,
            email: email,
            mdp: mdp
          })
        });

        const data = await response.json();

        if (!data.success) {
          alert(data.message || 'Erreur lors de la création.');
          return;
        }

        if (data.pilote) {
          pilotes.push(data.pilote);
          afficherPilote(data.pilote);
        } else {
          console.error('Réponse create sans pilote :', data);
        }

        document.getElementById('createPrenom').value = '';
        document.getElementById('createNom').value = '';
        document.getElementById('createEmail').value = '';
        document.getElementById('createPassword').value = '';

        alert(data.message || 'Compte pilote créé avec succès.');
      } catch (error) {
        alert('Erreur JavaScript / serveur lors de la création.');
        console.error(error);
      }
    }

    async function enregistrer() {
      const id = document.getElementById('ficheContent').dataset.id;
      const prenom = document.getElementById('fichePrenom').value.trim();
      const nom = document.getElementById('ficheNom').value.trim();
      const email = document.getElementById('ficheEmail').value.trim();

      if (!id) {
        alert('Aucun pilote sélectionné.');
        return;
      }

      if (!prenom || !nom || !email) {
        alert('Merci de remplir prénom, nom et email.');
        return;
      }

      try {
        const response = await fetch('/gestionComptePiloteAdmin', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            action: 'update',
            id: id,
            prenom: prenom,
            nom: nom,
            email: email
          })
        });

        const data = await response.json();

        if (!data.success) {
          alert(data.message || 'Erreur lors de la modification.');
          return;
        }

        if (data.pilote) {
          const index = pilotes.findIndex(p => p && String(p.ID_Utilisateur) === String(id));

          if (index !== -1) {
            pilotes[index] = data.pilote;
          } else {
            pilotes.push(data.pilote);
          }

          afficherPilote(data.pilote);
        } else {
          console.error('Réponse update sans pilote :', data);
        }

        alert(data.message || 'Compte pilote modifié avec succès.');
      } catch (error) {
        alert('Erreur JavaScript / serveur lors de la modification.');
        console.error(error);
      }
    }

    async function supprimerCompte() {
      const id = document.getElementById('ficheContent').dataset.id;

      if (!id) {
        alert('Aucun pilote sélectionné.');
        return;
      }

      if (!confirm('Voulez-vous vraiment supprimer ce compte pilote ?')) {
        return;
      }

      try {
        const response = await fetch('/gestionComptePiloteAdmin', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            action: 'delete',
            id: id
          })
        });

        const data = await response.json();

        if (!data.success) {
          alert(data.message || 'Erreur lors de la suppression.');
          return;
        }

        pilotes = pilotes.filter(p => p && String(p.ID_Utilisateur) !== String(id));

        document.getElementById('ficheContent').style.display = 'none';
        document.getElementById('fichePlaceholder').style.display = 'flex';
        document.getElementById('ficheContent').dataset.id = '';

        document.getElementById('ficheNomAffiche').textContent = '';
        document.getElementById('ficheEmailAffiche').textContent = '';
        document.getElementById('fichePrenom').value = '';
        document.getElementById('ficheNom').value = '';
        document.getElementById('ficheEmail').value = '';

        alert(data.message || 'Compte pilote supprimé avec succès.');
      } catch (error) {
        alert('Erreur JavaScript / serveur lors de la suppression.');
        console.error(error);
      }
    }

    document.addEventListener('DOMContentLoaded', function () {
      document.getElementById('creerForm').style.display = 'none';
      document.getElementById('ficheContent').style.display = 'none';
      document.getElementById('fichePlaceholder').style.display = 'flex';
    });
  </script>

{% endblock %}
