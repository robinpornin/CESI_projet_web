  <title>{% block title %}CESI-STAGES{% endblock %}</title>
  <link rel="stylesheet" href="/Styles.css">
</head>

<body>

<header>
  <div class="logo">CESI-STAGES</div>
  {% if app_user is defined and app_user %}
