{% extends "base.html.twig" %}

{% block title %}Contact Admin{% endblock %}

{% block content %}

<div class="bienvenue">
  <h1>
    Bienvenue sur <span>{{ platform_name }}</span>
  </h1>
  <p>
    Bienvenue sur la page de contact avec les admin, Vous avez besoin de cela pour : Obtenir un compte, Obtenir un nouveau mot de passe
  </p>
</div>

<div class="separateur"></div>

<div class="acces-section">
  <h2>Que voulez vous faire ?</h2>

  <div class="boutons">
    <a class="btn btn-connexion">
      Je veux obtenir un compte :
      -Envoyer un mail depuis l'addresse mail utilisée pour le compte
      -Indiquer nom et prénom
      Addresse mail : creation.compte@cesistages.fr
    </a>

    <a class="btn btn-invite">
      Je veux obtenir un nouveau mot de passe :
      -Envoyer un mail depuis l'addresse utilisée pour le compte dont le mot de passe à été perdu
      -L'Admin vérifiera votre identité
      -Un nouveau mot de passe temporaire sera envoyé
      -Vous devrez le modifier dans la gestion de compte
    </a>

  </div>
</div>

{% endblock %}