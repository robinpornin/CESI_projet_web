{% extends "base.html.twig" %}

{% block title %}Page des paramètres de l'entreprise{% endblock %}

{% block content %}

  <!-- bandeau -->
  <div class="bandeau">
    <div class="bandeau-icon">⚙️</div>
    <div class="bandeau-info">
      <span class="bandeau-titre">Paramètres de l'entreprise</span>
      <span class="bandeau-badge">Paramètres</span>
      <span class="bandeau-sous">Gérez les paramètres de cette entreprise partenaire.</span>
    </div>
  </div>

  <div class="separateur"></div>

  {% if erreur %}
    <div class="carte carte-liste">
      <span class="carte-icon">⚠️</span>
      <span class="carte-titre">Erreur</span>
      <span class="carte-desc">{{ erreur }}</span>
    </div>
  {% endif %}

  {% if entreprise %}
    <!-- fiche entreprise -->
    <div class="fiche">
      <div class="fiche-logo">🏢</div>
      <div class="fiche-info">
        <span class="fiche-nom">{{ entreprise.Nom_entreprise }}</span>
        <span class="fiche-meta">{{ entreprise.Secteur }} &nbsp;·&nbsp; {{ entreprise.Type_ }}</span>
      </div>
    </div>

    <div class="section-titre">Que voulez-vous faire ?</div>

    <!-- modifier -->
    <a class="action-carte" href="/modificationEntreprise?id={{ entreprise.ID_Entreprise }}">
      <span class="action-carte-icon">✏️</span>
      <div class="action-carte-info">
        <span class="action-carte-titre">Modifier l'entreprise</span>
        <span class="action-carte-desc">→ Mettre à jour les informations de l'entreprise</span>
      </div>
      <span class="action-carte-arrow">›</span>
    </a>

    <div class="divider"></div>

    <!-- supprimer -->
    <form method="post" action="/parametreEntreprise?id={{ entreprise.ID_Entreprise }}" onsubmit="return confirm('Voulez-vous vraiment supprimer cette entreprise ? Cette action est définitive.');">
      <input type="hidden" name="id_entreprise" value="{{ entreprise.ID_Entreprise }}">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

      <button type="submit" class="action-carte danger">
        <span class="action-carte-icon">🗑️</span>
        <div class="action-carte-info">
          <span class="action-carte-titre">Supprimer l'entreprise</span>
          <span class="action-carte-desc">→ Suppression définitive et irréversible</span>
        </div>
        <span class="action-carte-arrow">›</span>
      </button>
    </form>
  {% else %}
    <div class="carte carte-liste">
      <span class="carte-icon">⚠️</span>
      <span class="carte-titre">Entreprise introuvable</span>
      <span class="carte-desc">L'entreprise demandée n'existe pas ou plus.</span>
    </div>
  {% endif %}

{% endblock %}
