{% extends "base.html.twig" %}

{% block title %}Page de la recherche d'entreprise{% endblock %}

{% block content %}

<div class="top-section">
  <div class="bienvenue">
    <h1>Recherche <span>Entreprise</span></h1>
    <p>Trouvez une entreprise partenaire et accédez à sa fiche détaillée.</p>
  </div>
  <div class="search-bar">
    <form method="get" action="" style="display:flex; gap:10px; width:100%;">
      <input type="text" id="searchInput" name="search" placeholder="Nom, type, ville..." value="{{ search|default('') }}">
      <button class="btn-search" type="submit">Rechercher</button>
    </form>
  </div>
</div>

<div class="separateur"></div>

<div class="content-layout">

  <div class="liste-entreprises">
    <div class="liste-title">Liste des entreprises</div>
    <div id="listeContainer"></div>

    {% if totalPages > 1 %}
      <div class="pagination">
        {% if currentPage > 1 %}
          <a href="?page={{ currentPage - 1 }}&search={{ search|url_encode }}" class="page-btn">Précédent</a>
        {% endif %}

        {% for i in 1..totalPages %}
          {% if i == currentPage %}
            <span class="page-btn active">{{ i }}</span>
          {% else %}
            <a href="?page={{ i }}&search={{ search|url_encode }}" class="page-btn">{{ i }}</a>
          {% endif %}
        {% endfor %}

        {% if currentPage < totalPages %}
          <a href="?page={{ currentPage + 1 }}&search={{ search|url_encode }}" class="page-btn">Suivant</a>
        {% endif %}
      </div>
    {% endif %}
  </div>

  <div class="fiche-entreprise">
    <h3>Accéder à la fiche entreprise</h3>

    <div class="fiche-placeholder" id="fichePlaceholder">
      <span>Sélectionnez une entreprise pour voir sa fiche</span>
    </div>

    <div class="fiche-content" id="ficheContent">
      <div class="fiche-row">
        <span class="fiche-label">Nom</span>
        <span class="fiche-value" id="ficheNom">—</span>
      </div>
      <div class="fiche-row">
        <span class="fiche-label">Secteur</span>
        <span class="fiche-value" id="ficheSecteur">—</span>
      </div>
      <div class="fiche-row">
        <span class="fiche-label">Type</span>
        <span class="fiche-value" id="ficheType">—</span>
      </div>
      <div class="fiche-row">
        <span class="fiche-label">Email</span>
        <span class="fiche-value" id="ficheEmail">—</span>
      </div>
      <div class="fiche-row">
        <span class="fiche-label">Téléphone</span>
        <span class="fiche-value" id="ficheTel">—</span>
      </div>
      <div class="fiche-row">
        <span class="fiche-label">Note moyenne</span>
        <span class="fiche-value" id="ficheNote">—</span>
      </div>
      <button class="btn-fiche" id="btnFiche">Voir la fiche complète →</button>
    </div>
  </div>

</div>

<script>
  const entreprises = {{ entreprises | json_encode | raw }};

  let activeIndex = null;

  function renderEntreprises(list) {
    const container = document.getElementById('listeContainer');
    container.innerHTML = '';

    if (list.length === 0) {
      container.innerHTML = '<p style="color:#aaa;font-style:italic;font-size:0.85rem;padding:10px 0;">Aucune entreprise trouvée.</p>';
      return;
    }

    list.forEach((e, i) => {
      const card = document.createElement('div');
      card.className = 'entreprise-card' + (activeIndex === i ? ' active' : '');
      card.innerHTML = `
        <div class="card-info">
          <span class="card-name">${e.Nom_entreprise}</span>
          <span class="card-meta">${e.Type_}  ·  ${e.Secteur}</span>
        </div>
        <span class="card-arrow">›</span>
      `;
      card.onclick = () => selectEntreprise(i, list);
      container.appendChild(card);
    });
  }

  function selectEntreprise(index, list) {
    activeIndex = index;
    const e = list[index];

    document.getElementById('ficheNom').textContent = e.Nom_entreprise;
    document.getElementById('ficheSecteur').textContent = e.Secteur;
    document.getElementById('ficheType').textContent = e.Type_;
    document.getElementById('ficheEmail').textContent = e.Email_entreprise;
    document.getElementById('ficheTel').textContent = e.Telephone;
    document.getElementById('ficheNote').textContent = e.Note_moyenne ? e.Note_moyenne + ' / 5' : 'Aucune évaluation';

    document.getElementById('btnFiche').onclick = () => {
      window.location.href = `ficheEntreprise?id=${e.ID_Entreprise}`;
    };

    document.getElementById('fichePlaceholder').style.display = 'none';
    document.getElementById('ficheContent').classList.add('visible');

    renderEntreprises(list);
  }

  renderEntreprises(entreprises);
</script>

{% endblock %}
