{% extends "base.html.twig" %}

{% block title %}Accueil{% endblock %}

{% block content %}

<!-- bandeau -->
  <div class="bandeau">
    <div class="bandeau-icon">🏢</div>
    <div class="bandeau-info">
      <span class="bandeau-titre">Création d'une entreprise</span>
      <span class="bandeau-badge">Nouvelle entreprise</span>
      <span class="bandeau-sous">Remplissez le formulaire pour ajouter une entreprise partenaire.</span>
    </div>
  </div>

  <!-- main -->

    <div class="separateur"></div>

    <div class="form-card">
      <div class="form-card-header">
        <span style="font-size:1rem">🏭</span>
        <span class="form-card-header-titre">Formulaire de création</span>
      </div>

      <div class="form-body">

        <!-- identité -->
        <span class="section-label">Identité de l'entreprise</span>
        <div class="form-grid">
          <div class="form-group full">
            <label class="form-label">Nom de l'entreprise</label>
            <input class="form-input" type="text" id="nom" placeholder="Ex : TechCorp Solutions" maxlength="80" oninput="updateCount('nom','countNom',80)">
            <span class="char-count" id="countNom">0 / 80</span>
          </div>
          <div class="form-group">
            <label class="form-label">Forme juridique</label>
            <select class="form-select">
              <option value="">-- Choisir --</option>
              <option>SAS</option>
              <option>SARL</option>
              <option>SA</option>
              <option>EURL</option>
              <option>SNC</option>
              <option>Autre</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">SIRET</label>
            <input class="form-input" type="text" placeholder="Ex : 123 456 789 00012" maxlength="17">
          </div>
          <div class="form-group">
            <label class="form-label">Secteur d'activité</label>
            <select class="form-select">
              <option value="">-- Choisir --</option>
              <option>Informatique / Tech</option>
              <option>BTP / Génie Civil</option>
              <option>Industrie</option>
              <option>Finance / Banque</option>
              <option>Santé</option>
              <option>Commerce / Marketing</option>
              <option>Énergie</option>
              <option>Autre</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Taille de l'entreprise</label>
            <select class="form-select">
              <option value="">-- Choisir --</option>
              <option>TPE (1–9 salariés)</option>
              <option>PME (10–249 salariés)</option>
              <option>ETI (250–4999 salariés)</option>
              <option>Grande entreprise (5000+)</option>
            </select>
          </div>
        </div>

        <!-- coordonnées -->
        <span class="section-label">Coordonnées</span>
        <div class="form-grid">
          <div class="form-group full">
            <label class="form-label">Adresse</label>
            <input class="form-input" type="text" placeholder="Numéro, rue, avenue…">
          </div>
          <div class="form-group">
            <label class="form-label">Ville</label>
            <input class="form-input" type="text" placeholder="Ex : Paris">
          </div>
          <div class="form-group">
            <label class="form-label">Code postal</label>
            <input class="form-input" type="text" placeholder="Ex : 75001" maxlength="5">
          </div>
          <div class="form-group">
            <label class="form-label">Email de contact</label>
            <input class="form-input" type="email" placeholder="contact@entreprise.fr">
          </div>
          <div class="form-group">
            <label class="form-label">Téléphone</label>
            <input class="form-input" type="tel" placeholder="01 00 00 00 00">
          </div>
          <div class="form-group full">
            <label class="form-label">Site web</label>
            <input class="form-input" type="url" placeholder="https://www.entreprise.fr">
          </div>
        </div>

        <!-- description -->
        <span class="section-label">Présentation</span>
        <div class="form-group">
          <label class="form-label">Description de l'entreprise</label>
          <textarea class="form-textarea" id="desc" placeholder="Décrivez l'activité, les valeurs, l'environnement de travail…" maxlength="500" oninput="updateCount('desc','countDesc',500)"></textarea>
          <span class="char-count" id="countDesc">0 / 500</span>
        </div>

        <!-- domaines -->
        <span class="section-label">Domaines de stage proposés</span>
        <div class="form-group">
          <label class="form-label">Ajouter des domaines</label>
          <div class="tags-container" id="tagsContainer" onclick="document.getElementById('tagInput').focus()">
            <input class="tag-input" id="tagInput" type="text" placeholder="Ex : Dev Web, Data, Réseau… (Entrée pour valider)">
          </div>
          <span class="tags-hint">Appuyez sur Entrée ou virgule pour ajouter un domaine</span>
        </div>

        <!-- logo -->
        <span class="section-label">Logo de l'entreprise</span>
        <div class="upload-zone" onclick="document.getElementById('fileInput').click()">
          <span class="upload-icon">📁</span>
          <span class="upload-texte" id="uploadTexte">Glissez-déposez votre logo ici ou cliquez pour parcourir</span>
          <button class="upload-btn" type="button">Choisir un fichier</button>
          <input type="file" id="fileInput" accept="image/*" style="display:none" onchange="handleFile(event)">
        </div>

        <!-- actions -->
        <div class="form-actions">
          <button class="btn-submit" onclick="soumettre()">Créer l'entreprise</button>
          <button class="btn-reset" onclick="resetForm()">Réinitialiser</button>
        </div>

      </div>
    </div>

{% endblock %}