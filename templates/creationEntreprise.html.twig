{% extends "base.html.twig" %}

{% block title %}Page de création d'entreprise{% endblock %}

{% block content %}

<div class="bandeau">
  <div class="bandeau-icon">🏢</div>
  <div class="bandeau-info">
    <span class="bandeau-titre">Création d'une entreprise</span>
    <span class="bandeau-badge">Nouvelle entreprise</span>
    <span class="bandeau-sous">Remplissez le formulaire pour ajouter une entreprise partenaire.</span>
  </div>
</div>

<div class="separateur"></div>

<div class="form-card">
  <div class="form-card-header">
    <span style="font-size:1rem">🏭</span>
    <span class="form-card-header-titre">Formulaire de création</span>
  </div>

  <div class="form-body">

    {% if success %}
      <div style="color: green; margin-bottom: 15px; padding: 10px; border: 1px solid green; border-radius: 6px;">
        L'entreprise a bien été créée.
      </div>
    {% endif %}

    {% if error %}
      <div style="color: red; margin-bottom: 15px; padding: 10px; border: 1px solid red; border-radius: 6px;">
        {{ error }}
      </div>
    {% endif %}

    <form method="POST" action="">
      <span class="section-label">Informations de l'entreprise</span>

      <div class="form-grid">

        <div class="form-group full">
          <label class="form-label" for="nom_entreprise">Nom de l'entreprise</label>
          <input class="form-input" type="text" id="nom_entreprise" name="nom_entreprise" maxlength="255" required value="{{ form.nom_entreprise|default('') }}">
        </div>

        <div class="form-group">
          <label class="form-label" for="email_entreprise">Email entreprise</label>
          <input class="form-input" type="email" id="email_entreprise" name="email_entreprise" maxlength="255" required value="{{ form.email_entreprise|default('') }}">
        </div>

        <div class="form-group">
          <label class="form-label" for="secteur">Secteur</label>
          <input class="form-input" type="text" id="secteur" name="secteur" maxlength="255" required value="{{ form.secteur|default('') }}">
        </div>

        <div class="form-group">
          <label class="form-label" for="type">Type</label>
          <input class="form-input" type="text" id="type" name="type" maxlength="255" required value="{{ form.type|default('') }}">
        </div>

        <div class="form-group">
          <label class="form-label" for="nb_stagiaires">Nombre de stagiaires</label>
          <input class="form-input" type="number" id="nb_stagiaires" name="nb_stagiaires" min="0" required value="{{ form.nb_stagiaires|default('') }}">
        </div>

        <div class="form-group">
          <label class="form-label" for="telephone">Téléphone</label>
          <input class="form-input" type="text" id="telephone" name="telephone" maxlength="16" required value="{{ form.telephone|default('') }}">
        </div>

        <div class="form-group full">
          <label class="form-label" for="description_entreprise">Description de l'entreprise</label>
          <textarea class="form-textarea" id="description_entreprise" name="description_entreprise" maxlength="512" required>{{ form.description_entreprise|default('') }}</textarea>
        </div>

      </div>

      <div class="form-actions">
        <button class="btn-submit" type="submit">Créer l'entreprise</button>
        <button class="btn-reset" type="reset">Réinitialiser</button>
      </div>
    </form>

  </div>
</div>

{% endblock %}
