{% extends "base.html.twig" %}

{% block title %}Page Pilote{% endblock %}

{% block content %}

  <div class="bienvenue">
    <h1>Bienvenue, <span>{{ prenom }}</span> 👋</h1>
    <p>Recherchez des entreprises ou des offres de stage disponibles sur la plateforme.</p>
  </div>

  <div class="separateur"></div>

  <div class="bloc-actions">
    <h2>QUE VOULEZ-VOUS FAIRE ?</h2>

    <div class="search-rows">

      <div class="search-item">
        <form method="GET" action="/rechercheEntreprise" class="search-btn-row">
          <button type="submit" class="btn-rechercher">RECHERCHE ENTREPRISE</button>
        </form>
      </div>

      <div class="search-item">
        <form method="GET" action="/rechercheOffre" class="search-btn-row">
          <button type="submit" class="btn-rechercher">RECHERCHE OFFRE DE STAGE</button>
        </form>
      </div>

    </div>
  </div>

{% endblock %}
