{% extends "base.html.twig" %}

{% block title %}Page Pilote{% endblock %}

{% block content %}

  <div class="bienvenue">
    <h1>Bienvenue, <span>{{ prenom }}</span> 👋</h1>
    <p>Recherchez des entreprises ou des offres de stage disponibles sur la plateforme.</p>
  </div>

  <div class="separateur"></div>

  <div class="bloc-actions">
    <h2>Que voulez-vous faire ?</h2>

    <div class="search-rows">

      <div class="search-item">
        <label>Recherche d'entreprise</label>
        <form method="GET" action="/rechercheEntreprise" class="search-row">
          <input type="text" name="q" placeholder="Nom de l'entreprise...">
          <button type="submit" class="btn-rechercher">Rechercher</button>
        </form>
        <span class="hint">→ Redirige vers la liste des entreprises</span>
      </div>

      <div class="search-item">
        <label>Recherche d'offre de stage</label>
        <form method="GET" action="/rechercheOffre" class="search-row">
          <input type="text" name="q" placeholder="Titre, domaine, lieu...">
          <button type="submit" class="btn-rechercher">Rechercher</button>
        </form>
        <span class="hint">→ Redirige vers la liste des offres</span>
      </div>

    </div>
  </div>

{% endblock %}