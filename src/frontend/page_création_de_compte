<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Création de compte</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&display=swap" rel="stylesheet">
  <style>

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Montserrat', Arial, sans-serif;
      background-color: #ffffff;
      color: #111111;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* --- HEADER --- */
    header {
      background-color: #111111;
      padding: 18px 30px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .logo {
      font-size: 2rem;
      font-weight: 900;
      color: #FFD700;
      letter-spacing: 4px;
      text-transform: uppercase;
      font-family: 'Montserrat', sans-serif;
    }

    /* --- MAIN --- */
    main {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 50px 20px;
      gap: 28px;
    }

    /* bienvenue */
    .bienvenue {
      text-align: center;
      max-width: 500px;
    }

    .bienvenue h1 {
      font-size: 1.6rem;
      color: #111111;
      margin-bottom: 8px;
    }

    .bienvenue h1 span {
      color: #FFD700;
    }

    .bienvenue p {
      font-size: 0.95rem;
      color: #444444;
      line-height: 1.6;
    }

    /* separateur */
    .separateur {
      width: 60px;
      height: 4px;
      background-color: #FFD700;
      border-radius: 2px;
    }

    /* --- BLOCS COMMUNS --- */
    .bloc {
      background-color: #f9f9f9;
      border: 2px solid #111111;
      border-radius: 12px;
      padding: 28px 35px;
      max-width: 500px;
      width: 100%;
    }

    .bloc h2 {
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #111111;
      margin-bottom: 18px;
    }

    /* --- SELECTION TYPE DE COMPTE --- */
    .type-compte {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .type-compte label {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 0.9rem;
      font-weight: 700;
      color: #111111;
      cursor: pointer;
      padding: 10px 14px;
      border: 2px solid #e0e0e0;
      border-radius: 8px;
      transition: border-color 0.2s, background-color 0.2s;
    }

    .type-compte label:hover {
      border-color: #FFD700;
      background-color: #fffbea;
    }

    .type-compte input[type="radio"] {
      accent-color: #FFD700;
      width: 16px;
      height: 16px;
      cursor: pointer;
    }

    .type-compte input[type="radio"]:checked + span {
      color: #111111;
    }

    .type-compte label:has(input:checked) {
      border-color: #FFD700;
      background-color: #fffbea;
    }

    /* --- FORMULAIRE --- */
    .inputs {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .input-group {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .input-group label {
      font-size: 0.8rem;
      font-weight: 700;
      color: #111111;
    }

    .input-group input {
      padding: 10px 12px;
      border: 2px solid #111111;
      border-radius: 6px;
      font-size: 0.9rem;
      font-family: 'Montserrat', sans-serif;
      outline: none;
      background-color: #ffffff;
      transition: border-color 0.2s;
    }

    .input-group input:focus {
      border-color: #FFD700;
    }

    /* bouton créer compte */
    .btn-submit {
      margin-top: 6px;
      width: 100%;
      background-color: #FFD700;
      color: #111111;
      border: none;
      padding: 13px;
      border-radius: 8px;
      font-size: 0.95rem;
      font-weight: 900;
      font-family: 'Montserrat', sans-serif;
      cursor: pointer;
      text-transform: uppercase;
      transition: opacity 0.2s, transform 0.2s;
    }

    .btn-submit:hover {
      opacity: 0.85;
      transform: translateY(-2px);
    }

    /* --- LIEN CONNEXION --- */
    .lien-connexion {
      text-align: center;
      font-size: 0.85rem;
      color: #444444;
    }

    .lien-connexion a {
      color: #111111;
      font-weight: 700;
      text-decoration: none;
      border-bottom: 2px solid #FFD700;
      padding-bottom: 1px;
      transition: color 0.2s;
    }

    .lien-connexion a:hover {
      color: #FFD700;
    }

    /* --- FOOTER --- */
    footer {
      background-color: #111111;
      color: #aaaaaa;
      text-align: center;
      padding: 20px;
      font-size: 0.85rem;
    }

    footer span {
      color: #FFD700;
      font-weight: bold;
    }

    /* --- BOUTON RETOUR --- */
    .btn-retour {
      position: fixed;
      bottom: 18px;
      left: 18px;
      background-color: #ffffff;
      color: #111111;
      border: 2px solid #111111;
      padding: 8px 14px;
      border-radius: 6px;
      font-size: 0.8rem;
      font-weight: 700;
      text-decoration: none;
      transition: background-color 0.2s, color 0.2s;
    }

    .btn-retour:hover {
      background-color: #FFD700;
      border-color: #FFD700;
    }

    /* responsive */
    @media (max-width: 480px) {
      .bloc {
        padding: 20px 16px;
      }
    }

  </style>
</head>
<body>

  <!-- header -->
  <header>
    <div class="logo">CESI-STAGES</div>
  </header>

  <!-- contenu principal -->
  <main>

    <!-- bienvenue -->
    <div class="bienvenue">
      <h1>Créer votre <span>compte</span></h1>
      <p>Rejoignez la plateforme CESI-STAGES et accédez à toutes les offres de stage disponibles.</p>
    </div>

    <div class="separateur"></div>

    <!-- selection type de compte -->
    <div class="bloc">
      <h2>Sélectionner le type de compte à créer</h2>
      <div class="type-compte">
        <label>
          <input type="radio" name="type" value="pilote">
          <span>Compte Pilote</span>
        </label>
        <label>
          <input type="radio" name="type" value="entreprise">
          <span>Compte Entreprise</span>
        </label>
        <label>
          <input type="radio" name="type" value="etudiant">
          <span>Compte Étudiant</span>
        </label>
      </div>
    </div>

    <!-- formulaire infos -->
    <div class="bloc">
      <h2>Rentrer les informations suivantes</h2>
      <div class="inputs">
        <div class="input-group">
          <label for="email">Identifiant (email)</label>
          <input type="email" id="email" placeholder="exemple@cesi.fr">
        </div>
        <div class="input-group">
          <label for="password">Mot de passe</label>
          <input type="password" id="password" placeholder="••••••••">
        </div>
        <div class="input-group">
          <label for="confirm-password">Confirmation mot de passe</label>
          <input type="password" id="confirm-password" placeholder="••••••••">
        </div>
        <button class="btn-submit">Créer mon compte</button>
      </div>
    </div>

    <!-- lien connexion -->
    <p class="lien-connexion">
      Vous avez déjà un compte ? <a href="connexion.html">Connectez-vous</a>
    </p>

  </main>

  <!-- footer -->
  <footer>
    <p>&copy; 2026 <span>CESI-STAGES</span> — Tous droits réservés</p>
  </footer>

  <!-- bouton retour -->
  <a href="javascript:history.back()" class="btn-retour">&#8592; Retour</a>

</body>
</html>
